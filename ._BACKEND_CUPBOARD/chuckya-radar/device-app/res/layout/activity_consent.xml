<?xml version="1.0" encoding="utf-8"?>
<!-- CHUCKYA Safety Radar — Consent + Telemetry Sender -->
<!-- Present this screen BEFORE collecting any IMEI or location data -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="20dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050A14">

    <TextView
        android:id="@+id/title"
        android:text="CHUCKYA Safety Radar Consent"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#00F5FF"
        android:layout_marginBottom="12dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/body"
        android:text="Purpose: This app sends a signed telemetry ping to CHUCKYA Radar to detect safety risks and create auditable evidence for emergency response.\n\nData collected: App Instance ID (required). IMEI and precise location only if you explicitly enable them below.\n\nUse: Data is used only for safety detection, evidence generation, and lawful requests from emergency services. We will not share your data without your consent except as required by law.\n\nRetention: Non-incident data retained 90 days. Confirmed incidents retained up to 7 years for legal purposes.\n\nYou may revoke consent at any time in Settings."
        android:textColor="#CCCCCC"
        android:lineSpacingMultiplier="1.3"
        android:layout_marginBottom="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <CheckBox
        android:id="@+id/consent_appid"
        android:text="I consent to share App Instance ID"
        android:checked="true"
        android:enabled="false"
        android:textColor="#FFFFFF"
        android:buttonTint="#00F5FF"
        android:layout_marginBottom="8dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <CheckBox
        android:id="@+id/consent_imei"
        android:text="I consent to share IMEI (optional)"
        android:textColor="#FFFFFF"
        android:buttonTint="#00F5FF"
        android:layout_marginBottom="8dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <CheckBox
        android:id="@+id/consent_location"
        android:text="I consent to share precise location (optional)"
        android:textColor="#FFFFFF"
        android:buttonTint="#00F5FF"
        android:layout_marginBottom="20dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <Button
        android:id="@+id/agreeButton"
        android:text="Agree and Send Demo Ping"
        android:backgroundTint="#00F5FF"
        android:textColor="#050A14"
        android:textStyle="bold"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
</LinearLayout>
