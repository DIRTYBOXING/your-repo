{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Alerts per Minute",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(radar_alerts_total[1m])) * 60",
          "legendFormat": "alerts/min",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#00F5FF" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "title": "Ingest Latency (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(radar_ingest_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95 latency",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(radar_ingest_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50 latency",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 5 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#00FF88", "value": null },
              { "color": "#FFD700", "value": 0.5 },
              { "color": "#FF3366", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "title": "Signature Verification Success Rate",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(radar_signature_verified_total[5m])) / sum(rate(radar_signature_total[5m])) * 100",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#FF3366", "value": null },
              { "color": "#FFD700", "value": 80 },
              { "color": "#00FF88", "value": 95 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "Location Consent Share Rate",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(radar_consent_location_true_total[5m])) / sum(rate(radar_alerts_total[5m])) * 100",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#FFD700", "value": null },
              { "color": "#00FF88", "value": 50 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "False Positive Ratio (rolling 1h)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(radar_false_positive_total[1h])) / sum(rate(radar_alerts_total[1h])) * 100",
          "legendFormat": "FP %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "fixed", "fixedColor": "#FF3366" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#00FF88", "value": null },
              { "color": "#FFD700", "value": 5 },
              { "color": "#FF3366", "value": 15 }
            ]
          }
        }
      }
    },
    {
      "title": "Connected WebSocket Clients",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 14 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(radar_ws_clients_connected)",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#00F5FF" }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "Pending Evidence Approvals",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 14 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(radar_pending_approvals)",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#00FF88", "value": null },
              { "color": "#FFD700", "value": 5 },
              { "color": "#FF3366", "value": 20 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "Alerts by Mode",
      "type": "piechart",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 14 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (mode) (radar_alerts_total)",
          "legendFormat": "{{mode}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "code_black" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "#FF3366", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "code_red" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "#FF6B35", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "code_amber" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "#FFB347", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "code_yellow" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "#FFD700", "mode": "fixed" }
              }
            ]
          }
        ]
      }
    }
  ],
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["dfc", "chuckya", "radar"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "CHUCKYA Control Room",
  "uid": "chuckya-control-room",
  "version": 1
}
