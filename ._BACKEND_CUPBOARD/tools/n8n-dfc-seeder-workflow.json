        "caption": "={{ $('Map to Blotato Format').item.json.CAPTION }}"
      },
      "id": "post-x",
      "name": "Post → X (Twitter)",
      "type": "@blotato/n8n-nodes-blotato.blotato",
      "typeVersion": 1,
      "position": [920, 460],
      "credentials": {
        "blotatoApi": {
          "id": "YOUR_BLOTATO_CREDENTIAL_ID",
          "name": "Blotato Pro"
        }
      }
    },
    {
      "parameters": {
        "resource": "post",
        "operation": "create",
        "platform": "threads",
        "mediaId": "={{ $json.mediaId }}",
        "caption": "={{ $('Map to Blotato Format').item.json.CAPTION }}"
      },
      "id": "post-threads",
      "name": "Post → Threads",
      "type": "@blotato/n8n-nodes-blotato.blotato",
      "typeVersion": 1,
      "position": [920, 560],
      "credentials": {
        "blotatoApi": {
          "id": "YOUR_BLOTATO_CREDENTIAL_ID",
          "name": "Blotato Pro"
        }
      }
    },
    {
      "parameters": {
        "resource": "post",
        "operation": "create",
        "platform": "linkedin",
