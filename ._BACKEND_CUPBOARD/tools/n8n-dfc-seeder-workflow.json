        "caption": "={{ $('Map to Blotato Format').item.json.CAPTION }}"
      },
      "id": "post-linkedin",
      "name": "Post → LinkedIn",
      "type": "@blotato/n8n-nodes-blotato.blotato",
      "typeVersion": 1,
      "position": [1150, 60],
      "credentials": {
        "blotatoApi": {
          "id": "YOUR_BLOTATO_CREDENTIAL_ID",
          "name": "Blotato Pro"
        }
      }
    },
    {
      "parameters": {
        "resource": "post",
        "operation": "create",
        "platform": "bluesky",
        "mediaId": "={{ $json.mediaId }}",
        "caption": "={{ $('Map to Blotato Format').item.json.CAPTION }}"
      },
      "id": "post-bluesky",
      "name": "Post → Bluesky",
      "type": "@blotato/n8n-nodes-blotato.blotato",
      "typeVersion": 1,
      "position": [1150, 160],
      "credentials": {
        "blotatoApi": {
          "id": "YOUR_BLOTATO_CREDENTIAL_ID",
          "name": "Blotato Pro"
        }
      }
    },
    {
      "parameters": {
        "resource": "post",
        "operation": "create",
        "platform": "pinterest",
        "mediaId": "={{ $json.mediaId }}",
        "caption": "={{ $('Map to Blotato Format').item.json.CAPTION }}"
      },
      "id": "post-pinterest",
      "name": "Post → Pinterest",
      "type": "@blotato/n8n-nodes-blotato.blotato",
      "typeVersion": 1,
      "position": [1150, 260],
      "credentials": {
        "blotatoApi": {
          "id": "YOUR_BLOTATO_CREDENTIAL_ID",
          "name": "Blotato Pro"
        }
      }
    },
    {
      "parameters": {
        "mode": "raw",
        "jsonOutput": "={{ {\n  \"eventId\": $('Map to Blotato Format').item.json.FIGHT_ID,\n  \"socialPostId\": $('Map to Blotato Format').item.json.SOCIAL_POST_ID,\n  \"status\": \"posted\",\n  \"platforms\": {\n    \"instagram\": $('Post → Instagram').item.json.postUrl || '',\n    \"tiktok\": $('Post → TikTok').item.json.postUrl || '',\n    \"youtube_shorts\": $('Post → YouTube Shorts').item.json.postUrl || '',\n    \"facebook\": $('Post → Facebook').item.json.postUrl || '',\n    \"x\": $('Post → X (Twitter)').item.json.postUrl || '',\n    \"threads\": $('Post → Threads').item.json.postUrl || '',\n    \"linkedin\": $('Post → LinkedIn').item.json.postUrl || '',\n    \"bluesky\": $('Post → Bluesky').item.json.postUrl || '',\n    \"pinterest\": $('Post → Pinterest').item.json.postUrl || ''\n  }\n} }}"
      },
      "id": "build-postback",
      "name": "Build Post-Back Payload",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [1380, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://australia-southeast1-datafightcentral.cloudfunctions.net/n8nPostBack",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "data",
              "value": "={{ JSON.stringify($json) }}"
            }
          ]
        },
        "options": {}
      },
      "id": "postback-firebase",
      "name": "Post-Back to Firebase",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1600, 300],
      "notes": "Calls the n8nPostBack Cloud Function to update the PPV event doc with all live social media URLs. This closes the feedback loop."
    }
  ],
  "connections": {
    "DFC Webhook Trigger": {
      "main": [
