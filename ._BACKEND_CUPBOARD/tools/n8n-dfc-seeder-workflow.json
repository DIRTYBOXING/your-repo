{
  "name": "DFC Event Auto-Seeder → 9 Platforms via Blotato",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "dfc-event-seed",
        "responseMode": "onReceived",
        "responseData": "allEntries",
        "options": {}
      },
      "id": "webhook-trigger",
      "name": "DFC Webhook Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [250, 300],
      "webhookId": "dfc-event-seed"
    },
    {
      "parameters": {
        "mode": "raw",
        "jsonOutput": "={{ {\n  \"TITLE\": $json.title,\n  \"MEDIA_URL\": $json.posterUrl,\n  \"CAPTION\": $json.caption,\n  \"STATUS\": \"Ready to Post\",\n  \"FIGHT_ID\": $json.eventId,\n  \"PRICE\": $json.price,\n  \"BUY_LINK\": $json.buyLink,\n  \"PROMOTER\": $json.promoterName,\n  \"DESCRIPTION\": $json.description,\n  \"EVENT_DATE\": $json.eventDate,\n  \"SOCIAL_POST_ID\": $json.socialPostId\n} }}"
      },
      "id": "edit-fields",
      "name": "Map to Blotato Format",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [470, 300]
    },
    {
      "parameters": {
        "spreadsheetId": "YOUR_GOOGLE_SHEET_ID",
        "sheetName": "DFC_Events",
        "columns": "TITLE,MEDIA_URL,CAPTION,STATUS,FIGHT_ID,PRICE,BUY_LINK,PROMOTER,EVENT_DATE,SOCIAL_POST_ID",
        "options": {}
      },
      "id": "google-sheet-log",
      "name": "Log to Google Sheet",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [470, 520],
      "notes": "Optional: logs every seeded event to a Google Sheet for audit trail. Replace YOUR_GOOGLE_SHEET_ID with your actual sheet."
    },
    {
      "parameters": {
        "resource": "media",
        "operation": "upload",
        "url": "={{ $json.MEDIA_URL }}",
        "caption": "={{ $json.CAPTION }}"
      },
      "id": "blotato-upload",
      "name": "Blotato Upload Media",
      "type": "@blotato/n8n-nodes-blotato.blotato",
      "typeVersion": 1,
      "position": [690, 300],
      "credentials": {
        "blotatoApi": {
          "id": "YOUR_BLOTATO_CREDENTIAL_ID",
          "name": "Blotato Pro"
        }
      },
      "notes": "Uploads the poster image to Blotato. Requires @blotato/n8n-nodes-blotato community node installed and Blotato Pro API key configured."
    },
    {
      "parameters": {
        "resource": "post",
        "operation": "create",
        "platform": "instagram",
        "mediaId": "={{ $json.mediaId }}",
        "caption": "={{ $('Map to Blotato Format').item.json.CAPTION }}"
      },
      "id": "post-instagram",
      "name": "Post → Instagram",
      "type": "@blotato/n8n-nodes-blotato.blotato",
      "typeVersion": 1,
      "position": [920, 60],
      "credentials": {
        "blotatoApi": {
          "id": "YOUR_BLOTATO_CREDENTIAL_ID",
          "name": "Blotato Pro"
        }
      }
    },
    {
      "parameters": {
        "resource": "post",
        "operation": "create",
        "platform": "tiktok",
        "mediaId": "={{ $json.mediaId }}",
        "caption": "={{ $('Map to Blotato Format').item.json.CAPTION }}"
      },
      "id": "post-tiktok",
      "name": "Post → TikTok",
      "type": "@blotato/n8n-nodes-blotato.blotato",
      "typeVersion": 1,
      "position": [920, 160],
      "credentials": {
        "blotatoApi": {
          "id": "YOUR_BLOTATO_CREDENTIAL_ID",
          "name": "Blotato Pro"
        }
      }
    },
    {
      "parameters": {
        "resource": "post",
        "operation": "create",
        "platform": "youtube_shorts",
        "mediaId": "={{ $json.mediaId }}",
        "caption": "={{ $('Map to Blotato Format').item.json.CAPTION }}"
      },
      "id": "post-youtube",
      "name": "Post → YouTube Shorts",
      "type": "@blotato/n8n-nodes-blotato.blotato",
      "typeVersion": 1,
      "position": [920, 260],
      "credentials": {
        "blotatoApi": {
          "id": "YOUR_BLOTATO_CREDENTIAL_ID",
          "name": "Blotato Pro"
        }
      }
    },
    {
      "parameters": {
        "resource": "post",
        "operation": "create",
        "platform": "facebook",
        "mediaId": "={{ $json.mediaId }}",
        "caption": "={{ $('Map to Blotato Format').item.json.CAPTION }}"
      },
      "id": "post-facebook",
      "name": "Post → Facebook",
