#!/usr/bin/env bash
# в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# DFC pre-commit hook
#
# Install:
#   cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
#
# Or use the helper:
#   bash scripts/install_pre_commit_hook.sh
#
# Checks:
#   1. Block SVG files with embedded scripts or event handlers
#   2. Block accidental .env or secret key files from being committed
#   3. Run flutter analyze (only if Dart files are staged)
#   4. Run dart format --output=none --set-exit-if-changed (only if Dart files staged)
# в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

FAILED=0

# в”Ђв”Ђ Helper: get staged files matching a pattern в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
staged_files() {
  git diff --cached --name-only --diff-filter=ACM | grep -E "$1" || true
}

# в”Ђв”Ђ 1. SVG safety check в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
SVG_FILES=$(staged_files '\.svg$')
if [[ -n "$SVG_FILES" ]]; then
  echo "в–¶ Checking staged SVGs for embedded scripts..."
  while IFS= read -r f; do
    if grep -qiE '(<script|javascript:|on(load|error|click|mouse|focus|blur|key|drag|touch|wheel|resize|scroll|submit|reset|change|select|input|animation|transition)\s*=)' "$f" 2>/dev/null; then
      echo -e "  ${RED}вњ— BLOCKED${NC}: $f contains active content (script/event handler)"
      FAILED=1
    fi
  done <<< "$SVG_FILES"
  if [[ $FAILED -eq 0 ]]; then
    echo -e "  ${GREEN}вњ“ SVGs clean${NC}"
  fi
fi

# в”Ђв”Ђ 2. Secret file leak check в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
echo "в–¶ Checking for accidental secret files..."
SECRET_PATTERNS='(\.env$|\.env\.(local|production|staging|live)|google-services\.json|GoogleService-Info\.plist|service[-_]?account.*\.json|secrets\.json|\.pem$|\.p12$|\.keystore$)'
SECRET_FILES=$(staged_files "$SECRET_PATTERNS")
if [[ -n "$SECRET_FILES" ]]; then
  echo -e "  ${RED}вњ— BLOCKED${NC}: Attempting to commit sensitive files:"
  while IFS= read -r f; do
    echo -e "    ${RED}в†’ $f${NC}"
  done <<< "$SECRET_FILES"
  FAILED=1
else
  echo -e "  ${GREEN}вњ“ No secret files staged${NC}"
fi

# в”Ђв”Ђ 3. Inline secret pattern scan (staged content) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
echo "в–¶ Scanning staged content for secret patterns..."
# Only scan text files (not binary) staged for commit
INLINE_HITS=$(git diff --cached -U0 | grep -E '^\+' | grep -v '^\+\+\+' | \
  grep -iE '(sk_live_[a-zA-Z0-9]{20,}|whsec_[a-zA-Z0-9]{20,}|AIza[0-9A-Za-z\-_]{35}|ya29\.[0-9A-Za-z\-_]+|PRIVATE KEY|-----BEGIN RSA)' || true)
if [[ -n "$INLINE_HITS" ]]; then
  echo -e "  ${RED}вњ— BLOCKED${NC}: Possible secret values found in staged diff:"
  echo "$INLINE_HITS" | head -5
  echo -e "  ${YELLOW}  Review your diff with: git diff --cached${NC}"
  FAILED=1
else
  echo -e "  ${GREEN}вњ“ No inline secrets detected${NC}"
fi

# в”Ђв”Ђ 4. Dart format check в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
DART_FILES=$(staged_files '\.dart$')
if [[ -n "$DART_FILES" ]]; then
  echo "в–¶ Checking dart format..."
  if command -v dart &>/dev/null; then
    FORMAT_RESULT=$(dart format --output=none --set-exit-if-changed $DART_FILES 2>&1) || {
      echo -e "  ${RED}вњ— BLOCKED${NC}: Dart files not formatted. Run: dart format ."
      echo "$FORMAT_RESULT"
      FAILED=1
    }
    if [[ $FAILED -eq 0 ]]; then
      echo -e "  ${GREEN}вњ“ Dart format OK${NC}"
    fi
  else
    echo -e "  ${YELLOW}вљ   dart not found вЂ” skipping format check${NC}"
  fi
fi

# в”Ђв”Ђ 5. Flutter analyze (staged Dart files only) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
if [[ -n "$DART_FILES" ]]; then
  echo "в–¶ Running flutter analyze..."
  if command -v flutter &>/dev/null; then
    ANALYZE_OUT=$(flutter analyze --no-pub 2>&1) || {
      ERROR_COUNT=$(echo "$ANALYZE_OUT" | grep -c '^  error' || true)
      if [[ "$ERROR_COUNT" -gt 0 ]]; then
        echo -e "  ${RED}вњ— BLOCKED${NC}: flutter analyze found $ERROR_COUNT error(s):"
        echo "$ANALYZE_OUT" | grep '^  error' | head -10
        FAILED=1
      else
        echo -e "  ${YELLOW}вљ   flutter analyze had warnings (non-blocking)${NC}"
      fi
    }
    if [[ $FAILED -eq 0 ]]; then
      echo -e "  ${GREEN}вњ“ flutter analyze passed${NC}"
    fi
  else
    echo -e "  ${YELLOW}вљ   flutter not found вЂ” skipping analyze${NC}"
  fi
fi

# в”Ђв”Ђ Result в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
echo ""
if [[ $FAILED -ne 0 ]]; then
  echo -e "${RED}вњ— Pre-commit checks FAILED вЂ” commit blocked.${NC}"
  echo "  Fix the issues above and try again."
  echo "  To bypass (NOT recommended): git commit --no-verify"
  exit 1
fi

# в”Ђв”Ђ Playwright selector existence check on staged route screens в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
STAGED_DART=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null | grep -E 'lib/features/.*/screens/.*\.dart$' || true)
if [ -n "$STAGED_DART" ]; then
  MISSING_HOOK=""
  for f in $STAGED_DART; do
    if ! grep -qE 'setWebRouteTestHook|data-test|Semantics' "$f"; then
      MISSING_HOOK="$MISSING_HOOK\n  $f"
    fi
  done
  if [ -n "$MISSING_HOOK" ]; then
    echo -e "${YELLOW}вљ   WARN: Route screens without Playwright hook (add setWebRouteTestHook):${MISSING_HOOK}${NC}"
    # WARN only вЂ” not a hard block on commit
  fi
fi

echo -e "${GREEN}вњ“ All pre-commit checks passed.${NC}"
exit 0
