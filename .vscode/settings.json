{
  // ── COCKPIT MODE ──────────────────────────────────────────
  "workbench.startupEditor": "none",
  "workbench.statusBar.visible": true,
  "workbench.editor.showTabs": "multiple",
  "workbench.tree.indent": 12,
  "workbench.tree.renderIndentGuides": "none",
  "workbench.list.smoothScrolling": true,
  "workbench.editor.enablePreview": true,
  "explorer.autoReveal": true,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "search.showLineNumbers": true,
  "search.useIgnoreFiles": true,
  // ── EDITOR ────────────────────────────────────────────────
  "editor.minimap.enabled": false,
  "editor.breadcrumbs.enabled": false,
  "editor.lineNumbers": "relative",
  "editor.glyphMargin": false,
  "editor.folding": true,
  "editor.foldingHighlight": false,
  "editor.mouseWheelZoom": true,
  "editor.smoothScrolling": true,
  "editor.fontFamily": "'JetBrains Mono','Fira Code','Cascadia Code',monospace",
  "editor.fontSize": 13,
  "editor.lineHeight": 1.6,
  "editor.tabSize": 2,
  "editor.detectIndentation": true,
  "editor.insertSpaces": true,
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "explicit"
  },
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.eol": "\n",
  "files.autoSave": "afterDelay",
  "files.exclude": {
    "**/.env": true,
    "**/.env.local": true,
    "**/.venv": true,
    "**/venv": true,
    "**/node_modules": true,
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/.DS_Store": true,
    "**/.git": true
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/.venv/**": true,
    "**/venv/**": true
  },
  // ── PYTHON ────────────────────────────────────────────────
  "python.defaultInterpreterPath": "${workspaceFolder}/atlas_backend/venv/Scripts/python.exe",
  "python.linting.enabled": true,
  "python.linting.pylintEnabled": true,
  "python.formatting.provider": "black",
  "python.formatting.blackArgs": [
    "--line-length=100"
  ],
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.autoSearchPaths": true,
  "[python]": {
    "editor.defaultFormatter": "ms-python.python",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    }
  },
  // ── DART / FLUTTER ────────────────────────────────────────
  "dart.env": {},
  "[dart]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "Dart-Code.dart-code"
  },
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  // ── GIT / GITHUB ──────────────────────────────────────────
  "git.autofetch": false,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "gitlens.showWelcomeOnInstall": false,
  "github.copilot.enable": {
    "*": true
  },
  // ── TERMINAL ──────────────────────────────────────────────
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "terminal.integrated.defaultProfile.linux": "bash",
  "terminal.integrated.defaultProfile.osx": "bash",
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.lineHeight": 1.2,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.scrollback": 5000,
  // ── EXCLUDED EXTENSIONS (BLOCKED) ─────────────────────────
  "extensions.showRecommendationsOnly": true,
  "workbench.colorCustomizations": {},
  "firebridge.oauthProjectId": "datafightcentral",
  "antigravityCopilot.server.autoStart": true,
  "antigravityCopilot.server.enabled": true,
  "notebook.defaultFormatter": "punal100.antigravity-copilot",
  "GithubGistExplorer.explorer.subscriptionAscending": true,
  "i18n-ally.localesPaths": [
    "locales",
    "atlas_backend/venv/Lib/site-packages/anthropic/resources/messages",
    "atlas_backend/venv/Lib/site-packages/anthropic/types/messages",
    "atlas_backend/venv/Lib/site-packages/anthropic/resources/beta/messages",
    "atlas_backend/venv/Lib/site-packages/anthropic/types/beta/messages"
  ],
  "editor.codeActions.triggerOnFocusChange": true,
  "flutterTools.displayGetxContextMenu": false,
  "flutterTools.displayMobxContextMenu": false,
  "flutterTools.displayRiverpodContextMenu": false,
  "flutterTools.displayModularContextMenu": false,
  "flutterTools.displaySignalsContextMenu": false,
  // ── RELOAD HINT ───────────────────────────────────────────
  // After saving this file: Ctrl+Shift+P → "Developer: Reload Window"
  // Then install only the recommended essentials below.
}
