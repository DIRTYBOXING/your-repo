<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent"
    android:padding="16dp" android:background="#071029">

  <TextView android:id="@+id/title" android:layout_width="wrap_content" android:layout_height="wrap_content"
    android:text="CHUCKYA Control" android:textSize="20sp" android:textColor="#E6EEF8" android:paddingBottom="12dp"/>

  <Button android:id="@+id/btnPair" android:layout_width="match_parent" android:layout_height="wrap_content"
    android:text="Pair Bracelet" />

  <TextView android:id="@+id/status" android:layout_width="match_parent" android:layout_height="wrap_content"
    android:text="Status: Idle" android:textColor="#CFE8FF" android:paddingTop="12dp"/>

  <ListView android:id="@+id/deviceList" android:layout_width="match_parent" android:layout_height="0dp"
    android:layout_weight="1" android:dividerHeight="8dp" />

</LinearLayout>
