rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── UTILITY FUNCTIONS ───
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return getUserRole() == 'admin';
    }

    // ─── IDENTITY ───
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update, delete: if isOwner(userId) || isAdmin();
    }

    // ─── COMMERCE & PPV ───
    match /ppvEvents/{eventId} {
      allow read: if true;
      allow write: if isAdmin() || getUserRole() == 'promoter';
    }

    match /ppvPurchases/{purchaseId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow write: if false; // Strictly written by Stripe Webhooks
    }

    match /subscriptions/{subId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      // Writes should only come from a trusted server/webhook environment
      allow write: if false;
    }

    match /watchHistory/{docId} {
      allow read, write: if isOwner(resource.data.userId);
    }

    // ─── ECONOMY & PAYOUTS ───
    match /revenueEvents/{revId} {
      allow read: if isAdmin() ||
                  resource.data.participants.promoter == request.auth.uid ||
                  request.auth.uid in resource.data.participants.fighters;
      allow write: if false; // Strictly written by Stripe Webhooks
    }

    match /payoutBalances/{balanceId} {
      // balanceId format is '{ownerType}_{ownerId}'
      allow read: if isAdmin() || isOwner(resource.data.ownerId);
      allow write: if false; // Strictly written by Split Engine
    }

    match /payoutStatements/{statementId} {
      allow read: if isAdmin() || isOwner(resource.data.ownerId);
      allow write: if false;
    }

    // ─── TELEMETRY & AI ───
    match /telemetry/{docId} {
      allow create: if isOwner(request.resource.data.fighterId);
      allow read: if isOwner(resource.data.fighterId) || isAdmin();
      allow update, delete: if false; // Append-only immutable log
    }

    match /ai_insights/{fighterId} {
      allow read: if isOwner(fighterId) || isAdmin();
      allow write: if false; // Strictly written by Vertex AI PubSub Jobs
    }

    match /selfCheckReports/{reportId} {
      allow read: if isAdmin();
      allow write: if false; // Strictly written by Self-Check Engine
    }

    // ─── SPONSORSHIP SYSTEM ───
    match /sponsorPlacements/{placementId} {
      allow read: if true;
      allow write: if isAdmin() || getUserRole() == 'promoter';
    }

    match /sponsorBids/{bidId} {
      allow read: if isAdmin() || isOwner(resource.data.brandId) || (getUserRole() == 'promoter' && resource.data.promoterId == request.auth.uid);
      allow create: if getUserRole() == 'sponsor' || isAdmin();
      allow update, delete: if isAdmin();
    }

    // ─── CHUKYA RADAR SYSTEM ───
    // Critical security: Only the user can manage their own watchlist and safe zones.
    // Alerts are immutable logs written by a trusted service account (via Cloud Functions).
    match /threat_watchlist/{profileId} {
      allow read, create, update, delete: if isOwner(request.resource.data.victimUserId) || isOwner(resource.data.victimUserId);
    }

    match /safe_zones/{zoneId} {
      allow read, create, update, delete: if isOwner(request.resource.data.userId) || isOwner(resource.data.userId);
    }

    match /proximity_alerts/{alertId} {
      allow read: if isOwner(resource.data.victimUserId) || isAdmin();
      // Proximity alerts should be append-only, created by a backend service.
      // A user can only update the 'status' to acknowledge/resolve.
      allow create: if false;
      allow update: if isOwner(resource.data.victimUserId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'resolvedAt']);
      allow delete: if false;
    }

    match /safety_notifications/{notificationId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow write: if false; // Written by backend service only
    }
  }
}
