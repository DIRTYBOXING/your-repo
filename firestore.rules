rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ─── UTILITY FUNCTIONS ───
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return getUserRole() == 'admin';
    }

    // ─── IDENTITY ───
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update, delete: if isOwner(userId) || isAdmin();
    }

    // ─── COMMERCE & PPV ───
    match /ppvEvents/{eventId} {
      allow read: if true;
      allow write: if isAdmin() || getUserRole() == 'promoter';
    }

    match /ppvPurchases/{purchaseId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow write: if false; // Strictly written by Stripe Webhooks
    }

    match /watchHistory/{docId} {
      allow read, write: if isOwner(resource.data.userId);
    }

    // ─── ECONOMY & PAYOUTS ───
    match /revenueEvents/{revId} {
      allow read: if isAdmin() || 
                  resource.data.participants.promoter == request.auth.uid ||
                  request.auth.uid in resource.data.participants.fighters;
      allow write: if false; // Strictly written by Stripe Webhooks
    }

    match /payoutBalances/{balanceId} {
      // balanceId format is '{ownerType}_{ownerId}'
      allow read: if isAdmin() || isOwner(resource.data.ownerId);
      allow write: if false; // Strictly written by Split Engine
    }

    match /payoutStatements/{statementId} {
      allow read: if isAdmin() || isOwner(resource.data.ownerId);
      allow write: if false;
    }

    // ─── TELEMETRY & AI ───
    match /telemetry/{docId} {
      allow create: if isOwner(request.resource.data.fighterId);
      allow read: if isOwner(resource.data.fighterId) || isAdmin();
      allow update, delete: if false; // Append-only immutable log
    }

    match /ai_insights/{fighterId} {
      allow read: if isOwner(fighterId) || isAdmin();
      allow write: if false; // Strictly written by Vertex AI PubSub Jobs
    }

    match /selfCheckReports/{reportId} {
      allow read: if isAdmin();
      allow write: if false; // Strictly written by Self-Check Engine
    }

    // ─── SPONSORSHIP SYSTEM ───
    match /sponsorPlacements/{placementId} {
      allow read: if true;
      allow write: if isAdmin() || getUserRole() == 'promoter';
    }
    
    match /sponsorBids/{bidId} {
      allow read: if isAdmin() || isOwner(resource.data.brandId) || (getUserRole() == 'promoter' && resource.data.promoterId == request.auth.uid);
      allow create: if getUserRole() == 'sponsor' || isAdmin();
      allow update, delete: if isAdmin();
    }
  }
}