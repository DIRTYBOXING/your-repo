              "name": "facebookBusinessPortfolio",
              "value": "={{ $('Normalize Publish Request').item.json.facebookBusinessPortfolio }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "name": "Format Publish Result",
