import { pullJob, ackJob, retryJob, pushDLQ } from './lib/queue';
import { getCampaign, writeCampaignRun } from './lib/db';
import { evaluate } from './lib/ruleEngine';
import { generateAssets } from './lib/aiOrchestrator';
import { publish } from './lib/distributor';
import { useState } from 'react';
import 'dart:developer' as console;

async function mainLoop() {
  while(true) {
    const job = await pullJob('promotion_jobs');
    try {
      if (job.attempts > 5) {
        await pushDLQ('promotion_dlq', job);
        continue;
      }
      const campaign = await getCampaign(job.campaign_id);
      if (!campaign || campaign.status !== 'active') { await ackJob(job); continue; }
      const resolved = evaluate(campaign.rules, job.context);
      const assets = await generateAssets(job.media_id, campaign, resolved);
      const best = selectBest(assets);
      const result = await publish(best, job.channel, campaign);
      await writeCampaignRun({ ...job, result, resolved_rules: resolved });
      await ackJob(job);
    } catch (err) {
      if (isTransient(err)) {
        job.attempts = (job.attempts || 0) + 1;
        await retryJob(job, exponentialBackoff(job.attempts));
      } else {
        await pushDLQ('promotion_dlq', job);
      }
    }
  }
}
mainLoop();

