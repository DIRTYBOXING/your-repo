export default function CampaignEditor({ campaign }) {
  const [name, setName] = useState(campaign?.name || '');
  const [markets, setMarkets] = useState(campaign?.markets || []);
  const [channels, setChannels] = useState(campaign?.channels || []);
  const [rules, setRules] = useState(campaign?.rules || []);
  // AI generate variants
  async function onGenerateVariants() {
    const res = await api.post('/ai/generate-variants', { campaignId: campaign.id });
    // update UI with returned variants
  }
  return (
    <div className="campaign-editor">
      <input value={name} onChange={e => setName(e.target.value)} />
      <MarketSelector value={markets} onChange={setMarkets} />
      <ChannelCheckboxes value={channels} onChange={setChannels} />
      <RuleEditor rules={rules} onChange={setRules} />
      <button onClick={onGenerateVariants}>AI Generate Variants</button>
      <PreviewPanel campaign={{name, markets, channels, rules}} />
