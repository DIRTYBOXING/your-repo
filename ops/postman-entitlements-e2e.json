}

// CampaignList extends StatelessWidget
class CampaignList extends StatelessWidget {
  final List<Campaign> campaigns;
  @override
  Widget build(BuildContext context) {
    return ListView.builder(
      itemCount: campaigns.length,
      itemBuilder: (ctx, i) {
        final c = campaigns[i];
        return ListTile(
          title: Text(c.name),
          subtitle: Text('${c.markets.join(", ")} • ${c.status}'),
          trailing: PopupMenuButton(
            itemBuilder: (_) => [
              PopupMenuItem(child: Text('Preview')),
              PopupMenuItem(child: Text('Canary')),
              PopupMenuItem(child: Text('Pause')),
            ],
          ),
          onTap: () => Navigator.pushNamed(context, '/campaign/${c.id}'),
        );
      },
    );
  }
}
