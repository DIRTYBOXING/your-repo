{
  "type": "module",
  "scripts": {
    "genkit:hello": "node genkit/hello.mjs",
    "seed:real-event": "node scripts/seed_real_event_bundle.cjs",
    "upload:event-poster": "node scripts/upload_event_poster.cjs",
    "chukya:test": "node tools/inject_chukya_assert_admin.js",
    "verify:emulator": "pwsh -ExecutionPolicy Bypass -File scripts/verify_emulator_lane.ps1",
    "dev:api": "npx nodemon server/index.js --watch server",
    "dev:worker": "npx nodemon dfc-content-pipeline/video-worker/src/worker.js --watch dfc-content-pipeline/video-worker/src",
    "dev:ssr": "npx nodemon server/og-clip-ssr.js --watch server",
    "start:compose": "docker-compose up --build",
    "start:infra": "bash scripts/run_all.sh",
    "start:serverless": "cd serverless && npx serverless offline start --httpPort 3001",
    "stop:all": "bash scripts/stop_all.sh",
    "test:harness": "node scripts/test-job-runner.js",
    "smoke": "bash ci/smoke_clip_publish_strict.sh",
    "ppv:prepare-replay": "node scripts/prepare_ppv_replay.cjs",
    "load:checkout": "k6 run load/checkout_and_token.js",
    "load:playback": "k6 run load/playback_startup.js",
    "logs:collect": "bash scripts/collect_event_logs.sh",
    "lint": "npx eslint . --ext .js,.ts",
    "format": "npx prettier --write . --ignore-unknown || true",
    "test": "echo \"Tests: run flutter test for Dart\" && exit 0",
    "db:migrate": "npm run migrate",
    "migrate": "psql \"host=localhost port=5432 user=postgres dbname=datafight\" -f sql/001_create_media_uploads.sql",
    "deploy:serverless": "cd serverless && npx serverless deploy --stage staging",
    "deploy:firebase": "cd functions && npm ci && npx firebase deploy --only functions",
    "start:orchestrator": "node tools/task-orchestrator.js",
    "start:pm2": "pm2 resurrect || pm2 start ecosystem.config.js",
    "test:visual": "playwright test",
    "test:visual:headed": "playwright test --headed",
    "test:visual:ppv": "playwright test test/visual/ppv_surfaces.spec.ts test/visual/ppv_purchase_e2e.spec.ts test/visual/player-poster.spec.ts",
    "test:visual:social": "playwright test tests/playwright/social-messaging-smoke.spec.ts --project=desktop",
    "test:visual:ppv-maps-social": "playwright test test/visual/dfc_platform_audit.spec.ts --grep \"PPV|Social|Maps\"",
    "ppv:gate": "pwsh -ExecutionPolicy Bypass -File scripts/ppv_production_gate.ps1",
    "mux:deploy:serial": "pwsh -ExecutionPolicy Bypass -File scripts/deploy_mux_streaming_core.ps1",
    "mux:verify": "pwsh -ExecutionPolicy Bypass -File scripts/verify_mux_streaming_core.ps1",
    "social:smoke": "bash ops/social_messaging_smoke.sh",
    "social:weekly": "bash ops/social_messaging_weekly_sweep.sh",
    "weekly:sweep": "bash ops/weekly_sweep.sh",
    "seed:poster": "bash ops/seed_posters.sh",
    "docker:health": "pwsh -ExecutionPolicy Bypass -File scripts/docker_health.ps1",
    "live:codelab": "bash ops/gcp_live_codelab.sh",
    "live:codelab:dry": "bash ops/gcp_live_codelab.sh --dry-run",
    "live:check:manifests": "bash ops/check_manifests.sh",
    "live:lab:setup": "bash ops/live_streaming_codelab_setup.sh",
    "live:lab:ffmpeg": "bash ops/live_streaming_ffmpeg_test_signal.sh",
    "integration:enforce": "bash ops/integration_enforcement.sh",
    "avatars:audit": "node tools/avatar_profile_repair.mjs",
    "avatars:repair": "node tools/avatar_profile_repair.mjs --write",
    "firestore:probe": "node scripts/firestore_schema_probe.mjs",
    "firestore:seed-sample": "node scripts/firestore_import_sample_docs.mjs",
    "firestore:probe:strict": "node --experimental-modules scripts/firestore_schema_probe.mjs",
    "firestore:seed-sample:strict": "node --experimental-modules scripts/firestore_import_sample_docs.mjs",
    "firestore:migrate-dates:dry": "node scripts/firestore_migrate_dates_to_timestamps.mjs --dry-run",
    "firestore:migrate-dates": "node scripts/firestore_migrate_dates_to_timestamps.mjs"
  },
  "dependencies": {
    "@paypal/checkout-server-sdk": "^1.0.3",
    "@genkit-ai/firebase": "^1.28.0",
    "@genkit-ai/googleai": "^1.28.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "body-parser": "^2.2.2",
    "express": "^5.2.1",
    "firebase": "^11.10.0",
    "firebase-admin": "^13.6.1",
    "firebase-functions": "^7.2.5",
    "genkit": "^1.28.0",
    "ioredis": "^5.10.1",
    "multer": "^2.1.1",
    "node-fetch": "^3.3.2",
    "openai": "^6.22.0",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rss-parser": "^3.13.0",
    "sharp": "^0.34.5",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "install": "^0.13.0",
    "newman": "^6.2.2",
    "npm": "^11.10.1",
    "serverless-dotenv-plugin": "^6.0.0",
    "serverless-offline": "^13.8.0",
    "typescript": "^5.9.3",
    "vscode": "^1.1.37"
  }
